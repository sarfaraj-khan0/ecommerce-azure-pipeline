{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "avddevdf1"
		},
		"adls_link_Service_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'adls_link_Service'"
		},
		"azure_sql_LS_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'azure_sql_LS'"
		},
		"adls_link_Service_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://avddevalds.dfs.core.windows.net/"
		},
		"azure_sql_LS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "mydbserverr1.database.windows.net"
		},
		"azure_sql_LS_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "my_db"
		},
		"azure_sql_LS_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "avduser"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "avddevdf1_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"adls_link_Service_accountKey": {
						"value": "[parameters('adls_link_Service_accountKey')]"
					},
					"azure_sql_LS_password": {
						"value": "[parameters('azure_sql_LS_password')]"
					},
					"adls_link_Service_properties_typeProperties_url": {
						"value": "[parameters('adls_link_Service_properties_typeProperties_url')]"
					},
					"azure_sql_LS_properties_typeProperties_server": {
						"value": "[parameters('azure_sql_LS_properties_typeProperties_server')]"
					},
					"azure_sql_LS_properties_typeProperties_database": {
						"value": "[parameters('azure_sql_LS_properties_typeProperties_database')]"
					},
					"azure_sql_LS_properties_typeProperties_userName": {
						"value": "[parameters('azure_sql_LS_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}